# Copy this file to .env and fill in real values. Never commit .env — it's gitignored.

# Claude Code (headless, billed against your Claude Pro/Max subscription's
# usage allowance — no API key, no pay-per-token billing). Generate the
# token on a machine with a browser: install the `claude` CLI, log in with
# your Claude.ai account, run `claude setup-token`, then paste the printed
# token here — same "generate locally, paste into VPS .env" pattern as
# GOOGLE_OAUTH_REFRESH_TOKEN below. CLAUDE_BINARY only needs changing if
# `claude` isn't on PATH; leave CLAUDE_CODE_MODEL blank to use the CLI's
# own default model.
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_BINARY=claude
CLAUDE_CODE_MODEL=

# Local speech models (faster-whisper STT + Piper TTS) — fully offline, no
# account, no per-request billing. WHISPER_MODEL_SIZE downloads/caches
# automatically on first use. PIPER_VOICE_MODEL_PATH must point at a voice
# downloaded via `python scripts/download_piper_voice.py` (defaults to
# models/en_US-lessac-medium.onnx). PIPER_VOICE_CONFIG_PATH defaults to
# "<model path>.json" if left blank.
WHISPER_MODEL_SIZE=small
PIPER_VOICE_MODEL_PATH=models/en_US-lessac-medium.onnx
PIPER_VOICE_CONFIG_PATH=

# Telegram (create via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_OWNER_CHAT_ID=

# Google Calendar (OAuth "Desktop app" client — see scripts/google_oauth_setup.py)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
PRIMARY_CALENDAR_ID=itsabary@gmail.com

# Wiki / document access.
# Local dev (uvicorn run directly on this machine): relative paths next to
# the existing local clones.
# VPS deployment (see DEPLOY.md): set these to WIKI_REPO_PATH=/data/wiki and
# DOCS_REPO_PATH=/data/docs instead — docker-compose.yml bind-mounts the
# host clones (WIKI_HOST_PATH/DOCS_HOST_PATH below) to those container paths.
WIKI_REPO_PATH=../memory-module/wiki
WIKI_REPO_URL=https://github.com/itsabary13/butler-memory
DOCS_REPO_PATH=../document-module/files
DOCS_REPO_URL=https://github.com/itsabary13/butler-documents

# Fine-grained GitHub PAT, read/write, scoped ONLY to butler-memory + butler-documents
# (independently revocable from any interactively-used credential)
WIKI_GIT_TOKEN=

# Proactive notifications (v1.6 addendum, docs/architecture/voice-relay.md)
# — off by default; leave PROACTIVE_ENABLED unset/false until you've done
# the manual live-verification pass in DEPLOY.md. LOCAL_TIMEZONE (an IANA
# name, e.g. Asia/Jerusalem) controls both PROACTIVE_HOUR_LOCAL and quiet
# hours — leave as UTC if unset. Every other value below is a safe default,
# tunable without a code change/rebuild, just a container restart.
PROACTIVE_ENABLED=false
PROACTIVE_HOUR_LOCAL=8
LOCAL_TIMEZONE=UTC
PROACTIVE_LOOKAHEAD_DAYS=7
PROACTIVE_MAX_PER_DAY=3
PROACTIVE_COOLDOWN_DAYS=30
QUIET_HOURS_START=8
QUIET_HOURS_END=21

# --- VPS deployment only (docker-compose.yml / Caddyfile / DEPLOY.md) ---
# Public hostname Caddy requests a TLS cert for, e.g. jarvis.example.com
RELAY_DOMAIN=
# Host paths (on the VPS) containing the cloned private repos, bind-mounted
# into the container at /data/wiki and /data/docs.
WIKI_HOST_PATH=/opt/butler-memory
DOCS_HOST_PATH=/opt/butler-documents
