# Copy this file to .env and fill in real values. Never commit .env — it's gitignored.

# Anthropic (billed separately from your Claude Code/claude.ai subscription)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

# OpenAI (speech-to-text + text-to-speech)
OPENAI_API_KEY=

# Telegram (create via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_OWNER_CHAT_ID=

# Google Calendar (OAuth "Desktop app" client — see scripts/google_oauth_setup.py)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
PRIMARY_CALENDAR_ID=itsabary@gmail.com

# Wiki / document access — local path used first if it exists, else clone from the URL
WIKI_REPO_PATH=../memory-module/wiki
WIKI_REPO_URL=https://github.com/itsabary13/butler-memory
DOCS_REPO_PATH=../document-module/files
DOCS_REPO_URL=https://github.com/itsabary13/butler-documents

# Fine-grained GitHub PAT, read/write, scoped ONLY to butler-memory + butler-documents
# (independently revocable from any interactively-used credential)
WIKI_GIT_TOKEN=
